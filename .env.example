# Public API base URL used by the browser
# Keep it as /api when using nginx reverse proxy in production
VITE_API_BASE_URL=/api

# Target used by vite.config.ts for local/dev proxying
VITE_PROXY_TARGET=https://ekonstat.nkvtd.com

# Runtime upstream used by nginx inside the Docker container
# This should be the service hostname reachable on the Docker network
API_UPSTREAM=http://app:8080